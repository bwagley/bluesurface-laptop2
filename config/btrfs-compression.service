[Unit]
Description=Remount btrfs volumes with compress=zstd:1
DefaultDependencies=no
After=local-fs.target
Before=sysinit.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'findmnt -t btrfs -rno TARGET | while read -r mp; do mount -o remount,compress=zstd:1 "$mp"; done'
RemainAfterExit=yes

[Install]
WantedBy=sysinit.target
